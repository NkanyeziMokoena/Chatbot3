<Window x:Class="Chatbot3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chatbot3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="Black">
        <!-- 
      
      First screen: logo, welcome, and proceed button.
       -->
        <Grid x:Name="home_grid" Visibility="Visible">
            <Image Source="/Logo3.jpg" Height="200" Width="300" Margin="0,0,0,200"/>
            <TextBlock Text="Welcome to AI chatbot, click continue button"
                Height="20" Width="270" TextAlignment="Center"
                Margin="0,30,0,0" FontFamily="Arial Rounded MT Bold"/>
            <Button Height="40" Width="300" Margin="0,200,0,0"
             Content="Proceed" Click="proceed"
               Foreground="White"
              Background="Blue"/>
        </Grid>

        <!-- 
      
      Collects username before entering the main app.
       -->
        <Grid x:Name="username_grid" Visibility="Hidden">
            <Image Source="/Logo3.jpg" Height="200" Width="300" Margin="0,0,0,200"/>
            <TextBlock Text="Enter username"
                Height="20" Width="270" TextAlignment="Justify"
                Margin="0,30,0,0" FontFamily="Arial Rounded MT Bold"/>
            <TextBox Height="40" Width="270" TextAlignment="Center"
              Margin="0,100,0,0" FontFamily="Arial Rounded MT Bold"
              x:Name="usernames_input"/>
            <TextBlock Text="please enter username to continue..."
                Height="20" Width="270" TextAlignment="Justify"
                Margin="0,180,0,0" Foreground="Red"
                FontFamily="Arial Rounded MT Bold"/>
            <Button Height="40" Width="270" Margin="0,250,0,0"
             Content="Submit Username" Click="submit_name"/>
        </Grid>

        <!-- 
      MAIN APPLICATION PAGE
      Contains the sidebar and all content pages.
       -->
        <Grid Height="450" Width="800" x:Name="MainPage" Visibility="Hidden">

            <!-- Sidebar Navigation (right side) -->
            <Grid Margin="595,0,0,0" Background="Gray" Width="215">
                <StackPanel Grid.Column="0" Background="Gray"
                     Width="170" Margin="0,0,13,0">
                    <TextBlock Text="Menu" FontSize="18"
                        FontWeight="Bold" Margin="0,0,0,20"/>
                    <Button Content="Chats" Margin="0,5" Height="40" Click="chatting"/>
                    <Button Content="Add Task" Margin="0,5" Height="40" Click="addTaskPage"/>
                    <Button Content="Activity Log" Margin="0,5" Height="40" Click="activity"/>
                    <Button Content="Game" Margin="0,20,0,0" Height="40" Click="game"/>
                    <Button Content="Exit" Margin="0,20,0,0" Height="40" Click="exit"/>
                </StackPanel>
            </Grid>

            <!--
          
          Displays conversation and user input.
           -->
            <Grid Margin="0,0,205,0" x:Name="chat_page" Visibility="Visible">
                <ListView Margin="20,10,27,101" x:Name="chats"/>
                <TextBox Margin="20,356,158,44" x:Name="question" Height="50"/>
                <Button Content="Ask" Click="send" Height="50"
                 Margin="442,357,27,43"/>
            </Grid>

            <!-- 
     
          Lets the user create tasks, choose a reminder, and view tasks.
           -->
            <Grid Margin="0,0,205,0" x:Name="reminderPage" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Page Title -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                    Text="Add New Task" FontSize="20"
                    FontWeight="Bold" Margin="20,15,0,0"
                    Foreground="#2C3E50"/>

                <!-- Task Name -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                    Text="Task Name:" Margin="20,15,10,5"
                    FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                  x:Name="taskNameInput" Height="30"
                  Margin="0,10,10,5" Padding="5,0"
                  FontSize="14" Grid.ColumnSpan="2"/>

                <!-- Description  -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                    Text="Description:" FontWeight="SemiBold"
                    VerticalAlignment="Top"
                    Margin="20,10,10,5"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                  x:Name="taskDescriptionInput" Height="30"
                  Margin="0,5,10,5" Padding="5,0"
                  FontSize="14" Grid.ColumnSpan="2"/>

                <!-- Reminder Options -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                    Text="Reminder:" Margin="20,10,10,5"
                    FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="3" Grid.Column="1"
                     Orientation="Horizontal" Margin="0,10,10,5"
                     Grid.ColumnSpan="2">
                    <RadioButton x:Name="reminderNo" Content="No"
                          GroupName="ReminderOption" IsChecked="True"
                          Checked="reminderNo_Checked" Margin="0,0,15,0"/>
                    <RadioButton x:Name="reminderToday" Content="Today"
                          GroupName="ReminderOption"
                          Checked="reminderToday_Checked" Margin="0,0,15,0"/>
                    <RadioButton x:Name="reminderCustom" Content="In (days)"
                          GroupName="ReminderOption"
                          Checked="reminderCustom_Checked" Margin="0,0,10,0"/>
                    <TextBox x:Name="reminderDaysInput" Width="40"
                      Height="25" Margin="0,0,10,0"
                      IsEnabled="False" Text="3"/>
                    <TextBlock Text="days" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="4" Grid.ColumnSpan="3"
                     Orientation="Horizontal" Margin="20,10,0,10">
                    <Button Content="Add Task" Height="35" Width="120"
                     Click="AddTaskButton_Click"
                     Background="#27AE60" Foreground="White"
                     BorderThickness="0" Cursor="Hand"
                     FontWeight="SemiBold"/>
                    <Button Content="Clear" Height="35" Width="80"
                     Click="ClearTaskFields_Click"
                     Background="#95A5A6" Foreground="White"
                     BorderThickness="0" Cursor="Hand"
                     Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Task List (displays all tasks) -->
                <Border Grid.Row="5" Grid.ColumnSpan="3"
                 Margin="20,5,20,20"
                 Background="#F8F9FA" CornerRadius="8"
                 BorderBrush="#BDC3C7" BorderThickness="1"
                 Padding="5">
                    <ListView x:Name="view_tasks"
                       MouseDoubleClick="remind_append_MouseDoubleClick"
                       Background="Transparent"
                       BorderThickness="0"/>
                </Border>
            </Grid>

            <!--
          ACTIVITY LOG PAGE
          Shows user & system actions.
           -->
            <Grid Margin="0,0,205,0" x:Name="LogPage" Visibility="Hidden">
                <ListView Margin="20,10,27,87"
                   MouseDoubleClick="remind_append_MouseDoubleClick"
                   x:Name="log_append"/>
                <TextBlock Text="All the activities that happen here will be shown here."
                    TextAlignment="Center" Margin="20,368,14,36"
                    TextWrapping="Wrap" Foreground="Red"/>
            </Grid>

            <!-- 
          quez game Page
          A multiple‑choice cybersecurity quiz.
           -->
            <Grid Margin="0,0,205,0" x:Name="gamePage" Visibility="Hidden">
                <Grid Height="390px" x:Name="quizGame_page"
               Visibility="Visible" Margin="10,30,10,30">
                    <TextBlock Height="50px" Width="300px" Text="Question"
                        Foreground="SkyBlue" TextAlignment="Center"
                        FontSize="20px" x:Name="question_asked"
                        Margin="0,0,0,210"/>
                    <Button Height="40px" Width="300px" Background="Gray"
                     Content="" Foreground="white" FontSize="10px"
                     Margin="0,0,330,120" x:Name="optionButtonOne"
                     Click="optionSelected"/>
                    <Button Height="40px" Width="300px" Background="Gray"
                     Content="" Foreground="white" FontSize="10px"
                     Margin="330,0,0,120" x:Name="optionButtonTwo"
                     Click="optionSelected"/>
                    <Button Height="40px" Width="300px" Background="Gray"
                     Content="" Foreground="white" FontSize="10px"
                     Margin="0,0,330,0" x:Name="optionButtonThree"
                     Click="optionSelected"/>
                    <Button Height="40px" Width="300px" Background="Gray"
                     Content="" Foreground="white" FontSize="10px"
                     Margin="330,0,0,0" x:Name="optionButtonFour"
                     Click="optionSelected"/>
                    <Button Height="40px" Width="100px" Background="Red"
                     Content="Answer" Foreground="white"
                     HorizontalContentAlignment="Center"
                     Margin="0,140,0,0" Click="answerButton"/>
                    <TextBlock Height="60px" Width="100px" Text="Score"
                        Foreground="Gray" TextAlignment="Center"
                        FontSize="20px" Margin="-2,6,477,324"
                        x:Name="score_count"/>
                </Grid>
            </Grid>

            <!--
          INTEREST HISTORY PAGE
          Shows stored user interests from chat.
         -->
            <Grid Margin="0,0,205,0" x:Name="HistoryPage" Visibility="Hidden">
                <ListView Margin="20,10,27,87"
                   MouseDoubleClick="remind_append_MouseDoubleClick"
                   x:Name="history_append"/>
                <TextBlock Text="If no history listed then try to add some from the chats."
                    TextAlignment="Center" Margin="20,368,14,36"
                    TextWrapping="Wrap" Foreground="Red"/>
            </Grid>

        </Grid>
        <!-- End of Main Application Grid -->
    </Grid>
    <!-- end of parent grid -->
</Window>
